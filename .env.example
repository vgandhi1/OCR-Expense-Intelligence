# Copy to `.env` for local overrides. docker-compose already supplies these
# defaults, so a .env is optional unless you change ports/hosts.
# NEVER commit a real .env with secrets.

# MongoDB
MONGODB_URL=mongodb://mongo:27017

# Redis (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0

# Where the API/worker persist raw uploads (shared docker volume)
UPLOAD_ROOT=/data/uploads

# CORS origins for the API (comma-separated). Used by future config; the app
# currently hard-codes localhost:3000 and localhost:5173 in main.py.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Authentication ---
# Secret that protects POST /admin/tenants (issues tenant API keys). The admin
# endpoint is disabled (503) until this is set. Use a long random value in prod.
ADMIN_KEY=change-me-in-production
# Set to 1 to require a valid X-API-Key on every request, disabling the
# X-Tenant-ID dev fallback and the anonymous "default" tenant.
REQUIRE_API_KEY=0

# --- Rate limiting ---
# Set to 0 to disable rate limiting (e.g. in tests). Default on. (Distinct from
# slowapi's own RATELIMIT_ENABLED, which it consumes globally.)
APP_RATELIMIT_ENABLED=1
# Where slowapi stores counters. Use Redis to share limits across API replicas;
# defaults to in-process memory if unset. docker-compose sets this to Redis db 1.
RATELIMIT_STORAGE_URI=redis://redis:6379/1

# Logging
LOG_LEVEL=INFO
